component OverpressureReliefValve
% Overpressure Relief Valve (OPRV)
% Passive dump valve that vents gas when BCD internal pressure exceeds
% ambient by the cracking threshold (typically 2.5-4.0 psi gauge).

    annotations
        Icon = 'images/OverpressureReliefValve.svg';
    end

    nodes
        A = scuba.gas.underwaterGas;  % BCD side:left
        B = scuba.gas.underwaterGas;  % ambient side:right
    end

    parameters
        P_crack = {20684, 'Pa'};         % Cracking pressure (gauge) [3.0 psi]
        R_open  = {5000, 'Pa*s/mol'};    % Flow resistance when open
    end

    variables
        n_dot = {0, 'mol/s'};  % Flow A to B
    end

    branches
        n_dot : A.n_dot -> B.n_dot;
    end

    equations
        let
            p_gauge = A.p - B.p;
        in
            n_dot == if p_gauge > P_crack
                (p_gauge - P_crack) / R_open
            else
                {0, 'mol/s'}
            end;
        end
    end

end
